#!/usr/bin/env bash
set -euo pipefail

SKILLS_DEST="/home/quesadx/dotfiles/nix/modules/opencode/skills"
TEMP_DIR=$(mktemp -d /tmp/opencode-skill-import.XXXXXX)

cleanup() {
  rm -rf "$TEMP_DIR"
}
trap cleanup EXIT

if [ $# -eq 0 ]; then
  echo "Usage: $0 '<npx command to install skill>'"
  echo ""
  echo "Examples:"
  echo "  $0 'npx skills add vercel-labs/agent-skills --yes'"
  echo "  $0 'npx @openai/codex import-skill some-skill'"
  echo ""
  echo "How it works:"
  echo "  1. Runs the installer inside a temp directory"
  echo "  2. Scans for SKILL.md files"
  echo "  3. Copies each skill folder into $SKILLS_DEST"
  echo ""
  echo "Fallback (if the installer insists on writing to ~/.config/opencode/skills):"
  echo "  $0 --fallback '<npx command>'"
  exit 1
fi

FALLBACK=false
if [ "${1:-}" = "--fallback" ]; then
  FALLBACK=true
  shift
fi

COMMAND="$*"

if [ "$FALLBACK" = true ]; then
  echo "=== Fallback mode ==="
  echo "Running installer globally..."
  BACKUP_DIR="${SKILLS_DEST}.backup-$(date +%s)"
  echo "Backing up existing managed skills to $BACKUP_DIR"
  cp -r "$SKILLS_DEST" "$BACKUP_DIR"

  eval "$COMMAND"

  echo "=== Discovering installed skills ==="
  CONFIG_SKILLS="${HOME}/.config/opencode/skills"
  if [ -d "$CONFIG_SKILLS" ]; then
    for skill_dir in "$CONFIG_SKILLS"/*/; do
      name=$(basename "$skill_dir")
      if [ -f "${skill_dir}SKILL.md" ]; then
        echo "Found skill: $name"
        mkdir -p "$SKILLS_DEST/$name"
        cp "${skill_dir}SKILL.md" "$SKILLS_DEST/$name/SKILL.md"
        echo "  -> Copied to $SKILLS_DEST/$name/SKILL.md"
        # Copy any additional files (scripts, assets) the skill might need
        for extra in "${skill_dir}"*; do
          base=$(basename "$extra")
          if [ "$base" != "SKILL.md" ] && [ -f "$extra" ]; then
            cp "$extra" "$SKILLS_DEST/$name/$base"
            echo "  -> Copied $base"
          fi
        done
      fi
    done
  fi

  echo "=== Cleaning up unmanaged generated directory ==="
  echo "The installer may have written to $CONFIG_SKILLS."
  echo "On next rebuild, Home Manager will overwrite it."
  echo "If you want to remove unmanaged files now: rm -rf $CONFIG_SKILLS"
else
  echo "=== Temp import mode ==="
  echo "Staging in: $TEMP_DIR"
  cd "$TEMP_DIR"

  eval "$COMMAND" || true

  echo "=== Discovering SKILL.md files ==="
  found_skills=false
  while IFS= read -r -d '' skill_file; do
    dir=$(dirname "$skill_file")
    name=$(basename "$dir")
    echo "Found skill: $name ($skill_file)"
    mkdir -p "$SKILLS_DEST/$name"
    cp "$skill_file" "$SKILLS_DEST/$name/SKILL.md"
    found_skills=true
  done < <(find "$TEMP_DIR" -name "SKILL.md" -print0 2>/dev/null)

  # Some npx installers write directly to ~/.config/opencode/skills even when
  # run from a temp dir. Check there too.
  if [ -d "${HOME}/.config/opencode/skills" ]; then
    echo "Also checking ~/.config/opencode/skills for new skills..."
    while IFS= read -r -d '' skill_file; do
      dir=$(dirname "$skill_file")
      name=$(basename "$dir")
      # Only copy if we don't already have it
      if [ ! -f "$SKILLS_DEST/$name/SKILL.md" ] && [ "$name" != "." ]; then
        echo "Found skill: $name (from ~/.config/opencode/skills)"
        mkdir -p "$SKILLS_DEST/$name"
        cp "$skill_file" "$SKILLS_DEST/$name/SKILL.md"
        found_skills=true
      fi
    done < <(find "${HOME}/.config/opencode/skills" -maxdepth 2 -name "SKILL.md" -print0 2>/dev/null)
  fi

  if [ "$found_skills" = false ]; then
    echo ""
    echo "No SKILL.md files discovered. The installer may have used unexpected paths."
    echo ""
    echo "Try fallback mode:"
    echo "  $0 --fallback '$COMMAND'"
    echo ""
    echo "Or manually check what was installed:"
    echo "  find ~/.config/opencode/skills -name SKILL.md"
  fi
fi

echo ""
echo "=== Done ==="
echo "Skills copied to: $SKILLS_DEST"
echo ""
echo "Rebuild so Home Manager takes ownership:"
echo "  sudo nixos-rebuild switch --flake /home/quesadx/dotfiles#thinkpad-x13"
echo ""
echo "Verify:"
echo "  ls ~/.config/opencode/skills"
